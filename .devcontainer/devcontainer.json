{
  "name": "Chess Game Monorepo",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "chess_app",
  "workspaceFolder": "/workspaces/chessgame-elixir",

  "forwardPorts": [
    3000,
    3001,
    4000,
    5432,
    9000,
    9001,
    9999
  ],

  "portsAttributes": {
    "3000": { "label": "SaaS Landing Page", "onAutoForward": "openBrowser" },
    "3001": { "label": "Chess App", "onAutoForward": "openBrowser" },
    "4000": { "label": "Phoenix Backend", "onAutoForward": "notify" },
    "9001": { "label": "MinIO Console", "onAutoForward": "notify" },
    "9999": { "label": "GoTrue Auth", "onAutoForward": "notify" }
  },

  "postCreateCommand": "cd /workspaces/chessgame-elixir && pnpm install",

  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "typescript.preferences.importModuleSpecifier": "shortest",
        "tailwindCSS.experimental.classRegex": [
          ["cn\\(([^)]*)\\)", "\"([^\"]*)\""]
        ]
      }
    }
  },

  "remoteUser": "node"
}
