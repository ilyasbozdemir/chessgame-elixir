{
    "name": "chessgame-elixir",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "backend:dev": "cd apps/backend/chess_realtime_server && mix phx.server",
        "saas:dev": "pnpm --filter chess-game-saas dev",
        "app:dev": "pnpm --filter chess-game-app dev",
        "infra:up": "docker compose up -d db gotrue minio",
        "infra:down": "docker compose stop db gotrue minio",
        "dev": "pnpm run infra:up && concurrently -n \"BACKEND,SAAS,APP\" -c \"magenta,blue,green\" \"pnpm run backend:dev\" \"pnpm run saas:dev\" \"pnpm run app:dev\"",
        "dev:stop": "docker compose stop",
        "dev:clean": "docker compose down --volumes --remove-orphans",
        "v1:dev": "pnpm --filter chess-game-legacy dev",
        "v2:dev": "pnpm --filter chess-game-premium dev",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "docker:logs": "docker compose logs -f"
    },
    "devDependencies": {
        "concurrently": "^9.1.2"
    }
}